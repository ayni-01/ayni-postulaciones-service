{
  "info": {
    "name": "Somos Ayni — postulaciones-service",
    "description": "Endpoints del postulaciones-service (puerto 8084). Requiere JWT de identidad-service (puerto 8081).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_IDENTIDAD",
      "value": "http://localhost:8081"
    },
    {
      "key": "BASE_PERFILES",
      "value": "http://localhost:8082"
    },
    {
      "key": "BASE_RETOS",
      "value": "http://localhost:8083"
    },
    {
      "key": "BASE_POSTULACIONES",
      "value": "http://localhost:8084"
    },
    {
      "key": "BASE_HABILIDADES",
      "value": "http://localhost:8085"
    },
    {
      "key": "BASE_NOTIFICACIONES",
      "value": "http://localhost:8086"
    },
    {
      "key": "BASE_METRICAS",
      "value": "http://localhost:8087"
    },
    {
      "key": "TOKEN_EMPRESA",
      "value": ""
    },
    {
      "key": "TOKEN_TALENTO",
      "value": ""
    },
    {
      "key": "ID_EMPRESA",
      "value": ""
    },
    {
      "key": "ID_TALENTO",
      "value": ""
    },
    {
      "key": "RETO_ID",
      "value": ""
    },
    {
      "key": "POSTULACION_ID",
      "value": ""
    },
    {
      "key": "NOTIFICACION_ID",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Postular a Reto",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{TOKEN_TALENTO}}"
          }
        ],
        "url": {
          "raw": "{{BASE_POSTULACIONES}}/api/v1/postulaciones",
          "host": [
            "{{BASE_POSTULACIONES}}"
          ],
          "path": [
            "api",
            "v1",
            "postulaciones"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"retoId\":\"{{RETO_ID}}\",\"urlSolucion\":\"https://github.com/user/solucion\"}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var r=pm.response.json();pm.collectionVariables.set(\"POSTULACION_ID\",r.id);pm.test(\"201\",()=>pm.response.to.have.status(201));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Ver Postulaciones del Reto",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{TOKEN_EMPRESA}}"
          }
        ],
        "url": {
          "raw": "{{BASE_POSTULACIONES}}/api/v1/postulaciones/reto/{{RETO_ID}}",
          "host": [
            "{{BASE_POSTULACIONES}}"
          ],
          "path": [
            "api",
            "v1",
            "postulaciones",
            "reto",
            "{{RETO_ID}}"
          ]
        }
      }
    },
    {
      "name": "Historial del Talento",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{TOKEN_TALENTO}}"
          }
        ],
        "url": {
          "raw": "{{BASE_POSTULACIONES}}/api/v1/postulaciones/talento/{{ID_TALENTO}}",
          "host": [
            "{{BASE_POSTULACIONES}}"
          ],
          "path": [
            "api",
            "v1",
            "postulaciones",
            "talento",
            "{{ID_TALENTO}}"
          ]
        }
      }
    },
    {
      "name": "Evaluar Postulación (APROBADO)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{TOKEN_EMPRESA}}"
          }
        ],
        "url": {
          "raw": "{{BASE_POSTULACIONES}}/api/v1/postulaciones/{{POSTULACION_ID}}/evaluar",
          "host": [
            "{{BASE_POSTULACIONES}}"
          ],
          "path": [
            "api",
            "v1",
            "postulaciones",
            "{{POSTULACION_ID}}",
            "evaluar"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"puntuacion\":92,\"feedback\":\"Excelente trabajo\",\"resultado\":\"APROBADO\"}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    },
    {
      "name": "Evaluar Postulación (RECHAZADO)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{TOKEN_EMPRESA}}"
          }
        ],
        "url": {
          "raw": "{{BASE_POSTULACIONES}}/api/v1/postulaciones/{{POSTULACION_ID}}/evaluar",
          "host": [
            "{{BASE_POSTULACIONES}}"
          ],
          "path": [
            "api",
            "v1",
            "postulaciones",
            "{{POSTULACION_ID}}",
            "evaluar"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"puntuacion\":40,\"feedback\":\"Falta documentación\",\"resultado\":\"RECHAZADO\"}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_POSTULACIONES}}/actuator/health",
          "host": [
            "{{BASE_POSTULACIONES}}"
          ],
          "path": [
            "actuator",
            "health"
          ]
        }
      }
    }
  ]
}